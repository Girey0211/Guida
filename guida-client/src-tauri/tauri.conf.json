{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Guida",
  "version": "0.2.0",
  "identifier": "com.guida.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Guida",
        "label": "main",
        "width": 1100,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true
      },
      {
        "title": "Guida Overlay",
        "label": "overlay",
        "url": "index.html#/overlay",
        "width": 420,
        "height": 560,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://raw.githubusercontent.com https://*.cloudflare.com data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://raw.githubusercontent.com https://*.cloudflare.com"
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "endpoints": [
        "https://github.com/Girey0211/Guida/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMzMzUzQzVCRTA2NEQ4RDYKUldUVzJHVGdXencxTXpRSFpZRlVkY01Sb21MNTFnZEs0S0RTdEcyRW45bWl0SURIMHpYRE5oUjYK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
