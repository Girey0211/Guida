# 실 중앙 서버(guida-server) 연결 시 베이스 URL.
# 비워두면 로컬 Mock 서버(localStorage)로 동작한다.
# 예) 로컬 도커: http://localhost:3000  /  배포: https://api.example.com
VITE_API_BASE_URL=

# 게임 데이터(game_data.json / patch_version.json) 경로. 기본값: /data
# VITE_DATA_BASE_URL=/data

# 이미지 CDN(GitHub Raw → Cloudflare) 베이스 URL
# VITE_IMAGE_CDN_URL=
