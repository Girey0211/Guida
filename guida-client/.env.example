# 실 중앙 서버(guida-server) 베이스 URL. (필수 — 루트 공유/탐색/추천에 사용)
# 예) 로컬 도커: http://localhost:3000  /  배포: https://api.example.com
VITE_API_BASE_URL=http://localhost:3000

# 게임 데이터(game_data.json / patch_version.json) 경로. 기본값: /data (번들)
# CDN 사용 시 Worker 의 정적 데이터 엔드포인트를 가리킨다.
# VITE_DATA_BASE_URL=https://api.girey.org/data

# 이미지 CDN 베이스 URL. <base>/<image_key> 로 이미지 URL을 만든다.
# Cloudflare에 올린 베이스 경로(끝 슬래시 없이). 한글 파일명은 NFC로 통일해 업로드할 것.
# VITE_IMAGE_CDN_URL=https://<your-cloudflare-domain>/images
