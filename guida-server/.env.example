# PostgreSQL
POSTGRES_USER=guida
POSTGRES_PASSWORD=strong_password_here
POSTGRES_DB=guida_db
POSTGRES_PORT=5432
# DB 컨테이너 포트 바인드 주소. 기본 127.0.0.1(외부 차단).
# 로컬 서버 → 원격 DB(테일스케일) 연결 시 원격 호스트에서 테일스케일 IP 로 지정.
# 예) POSTGRES_BIND=100.78.207.60
# POSTGRES_BIND=127.0.0.1

# 로컬 dev 서버가 붙을 DB 호스트(서버 코드용). 도커 내부 실행 시 'db', 원격 직결 시 테일스케일 IP.
# POSTGRES_HOST=db

# Fastify 서버
SERVER_PORT=3000

# 실행 환경: development | production
NODE_ENV=production
